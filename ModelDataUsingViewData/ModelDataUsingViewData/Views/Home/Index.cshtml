@{
    ViewData["Title"] = "Home Page";

    // var emp = ViewData["myEmployee"] as Employee;
    // var emp = ViewBag.myEmployee;
    var emp = TempData["myEmployee"] as Employee;
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

@{
    if(emp != null)
    {
        <h2>Employee Id:         @emp.empId</h2>
        <h2>Employee Name:       @emp.empName</h2>
        <h2>Employee Designation:@emp.empDesignation</h2>
        <h2>Employee Salary:     @emp.empSalary</h2>
    }
}
