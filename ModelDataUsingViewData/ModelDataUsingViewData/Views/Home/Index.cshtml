@{
    ViewData["Title"] = "Home Page";

    // var emp = ViewData["myEmployee"] as Employee;
    // var emp = ViewBag.myEmployee;
    //var emp = TempData["myEmployee"] as Employee;

    //var emps = ViewData["myEmployee"] as List<Employee>;
    //var emps = ViewBag.myEmployee; 
    var emps = TempData["myEmployee"] as List<Employee>;
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

@{
    if(emps != null)
    {
        foreach(var e in emps)
        {
            <h4>Employee Id:         @e.empId</h4>
            <h5> Name:               @e.empName</h5>
            <h5>Employee Designation:@e.empDesignation</h5>
            <h5>Employee Salary:     @e.empSalary</h5>
            <p>--------------------------------------------</p>
        }
    }
}






