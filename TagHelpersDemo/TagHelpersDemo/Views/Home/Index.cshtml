@model TagHelpersDemo.Models.Employee;
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

<div class="container">
    <div class="row">
        <div class="col-sm-4">
            <form class="d-grid" asp-action="Index" asp-controller="Home" method="Post">
                <label asp-for="Name">
                    Employee Name:
                </label>
                <input asp-for="Name" class="form-control" placeholder="Enter Your Name" />
                <br />
                <select asp-for="Gender" class="form-control" asp-items="Html.GetEnumSelectList<Gender>()" placeholder="Gender">
                    <option value="">Select Gender</option>
                </select>
                <br />
                <input asp-for="Age" class="form-control" placeholder="Enter Your Age" />
                <br />
                <input asp-for="Designation" class="form-control" placeholder="Enter Your Desination" />
                <br />
                <input asp-for="Salary" class="form-control" placeholder="Enter Your Salary" />
                <br />
                <label asp-for="Married">
                    Married:
                </label>
                <div class="form-check">
                    <input id="flexRadioDefault1" class="form-check-input" type="radio" asp-for="Married" value="Yes" />
                    <label class="form-check-label" for="flexRadioDefault1">
                        Yes
                    </label>
                    <input id="flexRadioDefault2" class="form-check-input" type="radio" asp-for="Married" value="No" />
                    <label class="form-check-label" for="flexRadioDefault2">
                        No
                    </label>
                </div>
                <div class="form-check">
                    <br /><br />
                    <label asp-for="Description">
                        Description:
                    </label>
                    <textarea asp-for="Description" class="form-control" placeholder="Enter description" rows="6"></textarea>
                    <br />
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>




