@model ViewModelASPCore.Models.SchoolViewModel

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

<div class="row">
    <div class="col-md-12">
        @if(Model.myStudents.Any())
        {
             
        <h2>Students</h2>
        <table class="table table-striped table-dark table-hover table-border">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Gender</th>
                    <th>Class</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model.myStudents)
                {
                    <tr>
                        <td>@student.Id</td>
                        <td>@student.Name</td>
                        <td>@student.Gender</td>
                        <td>@student.Standard</td>
                    </tr>
                }
            </tbody>
        </table>
        } 
    
    else
    {
        <h2>No Students Found</h2>
    }
    </div>
    </div>



    <div class="row">
    <div class="col-md-12">
        @if(Model.myTeachers.Any())
        {
        <h2>Teachers</h2>
        <table class="table table-striped table-dark table-hover table-border">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Qualification</th>
                    <th>Salary</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var teacher in Model.myTeachers)
                {
                    <tr>
                        <td>@teacher.Id</td>
                        <td>@teacher.Name</td>
                        <td>@teacher.Qualification</td>
                        <td>@teacher.Salary</td>
                    </tr>
                }
            </tbody>
        </table>
   
        }
        else
        {
            <h2>No Teachers Found</h2>
        }
        </div>
        </div>
