@model IEnumerable<PartialViewASPCore.Models.Product>
@{
    ViewData["Title"] = "Product";
}

<h1>Product</h1>
<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            @* <partial name="_ProductPartialView" model="item" /> *@
            @await Html.PartialAsync("_ProductPartialView", item)
        </div>
    }
</div>